PORT=4000
NODE_ENV=development
APP_BASE_URL=http://localhost:4000
PERSISTENCE_DRIVER=json
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ventrapath

# Production / deploy note:
# - for single-service deploys that serve the frontend from the backend,
#   APP_BASE_URL can usually be omitted and will fall back to localhost internally.
# - for proper shared test deploys, switch to postgres persistence.
